{
	"openapi": "3.0.3",
	"info": {
		"description": "API's used and provided by [https://StellarAtlas.io](https://StellarAtlas.io).",
		"title": "StellarAtlas.io API",
		"contact": {
			"name": "StellarAtlas",
			"email": "info@StellarAtlas.io"
		},
		"version": "v1"
	},
	"servers": [
		{
			"url": "https://api.StellarAtlas.io",
			"description": "API for Stellar public network"
		},
		{
			"url": "https://api-testnet.StellarAtlas.io",
			"description": "API for Stellar testnet"
		}
	],
	"tags": [
		{
			"name": "Network",
			"description": "Information about the network"
		},
		{
			"name": "Node",
			"description": "Information about the nodes in the network"
		},
		{
			"name": "Organization",
			"description": "Information about the organizations in the network"
		},
		{
			"name": "HistoryScan",
			"description": "History archive verification evidence"
		},
		{
			"name": "SCP",
			"description": "Observed Stellar Consensus Protocol statements"
		},
		{
			"name": "Horizon",
			"description": "Discovered organization-operated Horizon API URLs"
		},
		{
			"name": "Subscription",
			"description": "Notification subscription management"
		}
	],
	"paths": {
		"/v1": {
			"get": {
				"summary": "Get network information",
				"description": "Get current network information, statistics, nodes, organizations, SCP analysis fields, and organization horizonUrl values when reported.",
				"tags": ["Network", "Horizon"],
				"operationId": "getNetwork",
				"parameters": [
					{
						"name": "at",
						"in": "query",
						"description": "Fetch at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "https://StellarAtlas.io/schemas/network.json"
								}
							}
						}
					}
				}
			}
		},
		"/v1/live": {
			"get": {
				"summary": "Stream live network information",
				"description": "Server-sent event stream that emits current network snapshots as network events for live dashboards.",
				"tags": ["Network"],
				"operationId": "streamNetwork",
				"responses": {
					"200": {
						"description": "server-sent event stream",
						"content": {
							"text/event-stream": {
								"schema": {
									"type": "string"
								}
							}
						}
					}
				}
			}
		},
		"/v1/search": {
			"get": {
				"summary": "Search network entities",
				"description": "Faceted search for current validators, nodes, organizations, and archive-related network metadata.",
				"tags": ["Network", "Node", "Organization"],
				"operationId": "searchNetworkEntities",
				"parameters": [
					{
						"name": "q",
						"in": "query",
						"description": "Search text",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "type",
						"in": "query",
						"description": "Optional entity type filter",
						"required": false,
						"schema": {
							"type": "string",
							"enum": ["node", "organization"]
						}
					},
					{
						"name": "limit",
						"in": "query",
						"description": "Maximum results to return",
						"required": false,
						"schema": {
							"type": "integer",
							"minimum": 1,
							"maximum": 50
						}
					}
				],
				"responses": {
					"200": {
						"description": "Search results",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"estimatedTotalHits": { "type": "integer" },
										"hits": {
											"type": "array",
											"items": {
												"type": "object",
												"properties": {
													"detail": { "type": "string" },
													"entityId": { "type": "string" },
													"entityType": {
														"type": "string",
														"enum": ["node", "organization"]
													},
													"href": { "type": "string" },
													"id": { "type": "string" },
													"label": { "type": "string" },
													"organizationName": { "type": "string" }
												},
												"required": [
													"detail",
													"entityId",
													"entityType",
													"href",
													"id",
													"label"
												]
											}
										},
										"indexedNetworkTime": { "type": "string" },
										"query": { "type": "string" },
										"source": {
											"type": "string",
											"enum": ["memory", "meilisearch"]
										}
									},
									"required": [
										"estimatedTotalHits",
										"hits",
										"indexedNetworkTime",
										"query",
										"source"
									]
								}
							}
						}
					}
				}
			}
		},
		"/v1/node-snapshots": {
			"get": {
				"summary": "Get the latest updated node snapshots in the network",
				"description": "Get the latest updated node snapshots in the network",
				"tags": ["Network"],
				"operationId": "getNetworkNodeSnapshots",
				"parameters": [
					{
						"name": "at",
						"in": "query",
						"description": "Latest snapshots at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "https://StellarAtlas.io/schemas/node-snapshot.json"
									}
								}
							}
						}
					}
				}
			}
		},
		"/v1/organization-snapshots": {
			"get": {
				"summary": "Get the latest updated organization snapshots in the network",
				"description": "Get the latest updated organization snapshots in the network",
				"tags": ["Network"],
				"operationId": "getNetworkOrganizationSnapshots",
				"parameters": [
					{
						"name": "at",
						"in": "query",
						"description": "Latest snapshots at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "https://StellarAtlas.io/schemas/organization-snapshot.json"
									}
								}
							}
						}
					}
				}
			}
		},
		"/v1/node": {
			"get": {
				"summary": "Get all nodes",
				"description": "Returns all the crawled nodes with statistics and geo data",
				"tags": ["Node"],
				"operationId": "getNodes",
				"parameters": [
					{
						"name": "at",
						"in": "query",
						"description": "Fetch at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "https://StellarAtlas.io/schemas/node.json"
									}
								}
							}
						}
					}
				}
			}
		},
		"/v1/node/{publicKey}": {
			"get": {
				"summary": "Get a node by public key",
				"description": "Returns the requested node with statistics and geo data",
				"tags": ["Node"],
				"operationId": "getNodeByPublicKey",
				"parameters": [
					{
						"name": "publicKey",
						"in": "path",
						"description": "Public Key of the node to return",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "at",
						"in": "query",
						"description": "Fetch at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "https://StellarAtlas.io/schemas/node.json"
								}
							}
						}
					},
					"404": {
						"description": "Node not found"
					}
				}
			}
		},
		"/v1/node/{publicKey}/snapshots": {
			"get": {
				"summary": "Get the latest snapshots of a node",
				"description": "Get the latest snapshots of a node",
				"tags": ["Node"],
				"operationId": "getNodeSnapshots",
				"parameters": [
					{
						"name": "publicKey",
						"in": "path",
						"description": "Public Key of the node to return",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "at",
						"in": "query",
						"description": "Latest snapshots at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "https://StellarAtlas.io/schemas/node-snapshot.json"
									}
								}
							}
						}
					}
				}
			}
		},
		"/v1/organization": {
			"get": {
				"summary": "Get all organizations",
				"description": "Returns all crawled organizations, including horizonUrl when reported by Stellar TOML metadata.",
				"tags": ["Organization", "Horizon"],
				"operationId": "getOrganizations",
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "https://StellarAtlas.io/schemas/organization.json"
									}
								}
							}
						}
					}
				}
			}
		},
		"/v1/organization/{id}": {
			"get": {
				"summary": "Get an organization by id",
				"description": "Returns the requested organization, including horizonUrl when reported by Stellar TOML metadata.",
				"tags": ["Organization", "Horizon"],
				"operationId": "getOrganizationById",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"description": "Id of the organization",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "at",
						"in": "query",
						"description": "Fetch at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "https://StellarAtlas.io/schemas/organization.json"
								}
							}
						}
					},
					"404": {
						"description": "Organization not found"
					}
				}
			}
		},
		"/v1/organization/{id}/snapshots": {
			"get": {
				"summary": "Get the latest snapshots of an organization",
				"description": "Get the latest snapshots of an organization",
				"tags": ["Organization"],
				"operationId": "getOrganizationSnapshots",
				"parameters": [
					{
						"name": "id",
						"in": "path",
						"description": "Id of the organization",
						"required": true,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "at",
						"in": "query",
						"description": "Latest snapshots at specific point in time",
						"required": false,
						"schema": {
							"type": "string",
							"format": "date-time"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"$ref": "https://StellarAtlas.io/schemas/organization-snapshot.json"
									}
								}
							}
						}
					}
				}
			}
		},
		"/v1/history-scan/{url}": {
			"get": {
				"summary": "Get the latest history scan by url",
				"description": "Returns the latest history scan by url",
				"tags": ["HistoryScan"],
				"operationId": "getHistoryScanByUrl",
				"parameters": [
					{
						"name": "url",
						"in": "path",
						"description": "url of the history archive (url encoded)",
						"required": true,
						"schema": {
							"type": "url"
						}
					}
				],
				"responses": {
					"200": {
						"description": "successful operation",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "https://StellarAtlas.io/schemas/history-archive-scan.json"
								}
							}
						}
					},
					"404": {
						"description": "No scan found for url"
					},
					"500": {
						"description": "Server error"
					}
				}
			}
		},
		"/v1/archive-scans/queue": {
			"get": {
				"summary": "Get archive scan queue stats",
				"description": "Returns a read-only queue snapshot for unfinished history archive scan jobs.",
				"tags": ["ArchiveScans"],
				"operationId": "getArchiveScanQueue",
				"responses": {
					"200": {
						"description": "queue snapshot",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"required": [
										"pendingJobs",
										"activeJobs",
										"staleJobs",
										"totalUnfinishedJobs",
										"generatedAt",
										"staleJobAgeMs"
									],
									"properties": {
										"pendingJobs": {
											"type": "integer",
											"minimum": 0
										},
										"activeJobs": {
											"type": "integer",
											"minimum": 0
										},
										"staleJobs": {
											"type": "integer",
											"minimum": 0
										},
										"totalUnfinishedJobs": {
											"type": "integer",
											"minimum": 0
										},
										"generatedAt": {
											"type": "string",
											"format": "date-time"
										},
										"staleJobAgeMs": {
											"type": "integer",
											"minimum": 0
										}
									}
								}
							}
						}
					},
					"500": { "description": "Server error" }
				}
			}
		},
		"/v1/archive-scans/workers": {
			"get": {
				"summary": "Get archive scan worker health",
				"description": "Returns a read-only worker-slot snapshot derived from currently taken archive scan jobs.",
				"tags": ["ArchiveScans"],
				"operationId": "getArchiveScanWorkers",
				"responses": {
					"200": {
						"description": "worker health snapshot",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"required": [
										"generatedAt",
										"staleJobAgeMs",
										"activeWorkers",
										"staleWorkers",
										"totalTakenJobs",
										"workers"
									],
									"properties": {
										"generatedAt": {
											"type": "string",
											"format": "date-time"
										},
										"staleJobAgeMs": { "type": "integer", "minimum": 0 },
										"activeWorkers": { "type": "integer", "minimum": 0 },
										"staleWorkers": { "type": "integer", "minimum": 0 },
										"totalTakenJobs": { "type": "integer", "minimum": 0 },
										"workers": {
											"type": "array",
											"items": {
												"type": "object",
												"required": [
													"archiveUrl",
													"status",
													"claimedAt",
													"lastHeartbeatAt",
													"heartbeatAgeMs",
													"fromLedger",
													"toLedger",
													"latestScannedLedger",
													"concurrency"
												],
												"properties": {
													"archiveUrl": { "type": "string", "format": "uri" },
													"status": {
														"type": "string",
														"enum": ["scanning", "stale"]
													},
													"claimedAt": {
														"type": "string",
														"format": "date-time"
													},
													"lastHeartbeatAt": {
														"type": "string",
														"format": "date-time"
													},
													"heartbeatAgeMs": {
														"type": "integer",
														"minimum": 0
													},
													"fromLedger": { "type": "integer", "minimum": 0 },
													"toLedger": {
														"type": "integer",
														"minimum": 0,
														"nullable": true
													},
													"latestScannedLedger": {
														"type": "integer",
														"minimum": 0
													},
													"concurrency": { "type": "integer", "minimum": 0 }
												}
											}
										}
									}
								}
							}
						}
					},
					"500": { "description": "Server error" }
				}
			}
		},
		"/v1/archive-scans/{encodedUrl}/errors": {
			"get": {
				"summary": "Get archive scan log entries",
				"description": "Returns recent completed scan entries and active queue entries for a history archive URL.",
				"tags": ["ArchiveScans"],
				"operationId": "getArchiveScanErrors",
				"parameters": [
					{
						"name": "encodedUrl",
						"in": "path",
						"description": "URL of the history archive, URL encoded",
						"required": true,
						"schema": { "type": "string", "format": "uri" }
					}
				],
				"responses": {
					"200": {
						"description": "archive scan log entries",
						"content": {
							"application/json": {
								"schema": {
									"type": "array",
									"items": {
										"type": "object",
										"required": [
											"url",
											"status",
											"errors",
											"hasArchiveVerificationError",
											"hasWorkerIssue",
											"latestVerifiedLedger",
											"latestScannedLedger",
											"fromLedger",
											"toLedger",
											"updatedAt"
										],
										"properties": {
											"url": { "type": "string", "format": "uri" },
											"status": {
												"type": "string",
												"enum": ["completed", "queued", "scanning", "stale"]
											},
											"errors": {
												"type": "array",
												"items": {
													"type": "object",
													"required": ["url", "message", "type"],
													"properties": {
														"url": { "type": "string" },
														"message": { "type": "string" },
														"type": { "type": "string" }
													}
												}
											},
											"hasArchiveVerificationError": { "type": "boolean" },
											"hasWorkerIssue": { "type": "boolean" },
											"latestVerifiedLedger": { "type": "integer" },
											"latestScannedLedger": { "type": "integer" },
											"fromLedger": { "type": "integer" },
											"toLedger": { "type": "integer", "nullable": true },
											"updatedAt": { "type": "string", "format": "date-time" }
										}
									}
								}
							}
						}
					},
					"400": { "description": "Invalid archive URL" },
					"500": { "description": "Server error" }
				}
			}
		},
		"/v1/archive-scans/{encodedUrl}": {
			"get": {
				"summary": "Get the latest archive scan by URL",
				"description": "Returns the latest history archive scan for a URL.",
				"tags": ["ArchiveScans"],
				"operationId": "getArchiveScanByUrl",
				"parameters": [
					{
						"name": "encodedUrl",
						"in": "path",
						"description": "URL of the history archive, URL encoded",
						"required": true,
						"schema": { "type": "string", "format": "uri" }
					}
				],
				"responses": {
					"200": {
						"description": "archive scan found",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "https://StellarAtlas.io/schemas/history-archive-scan.json"
								}
							}
						}
					},
					"204": { "description": "No scan found for URL" },
					"400": { "description": "Invalid archive URL" },
					"500": { "description": "Server error" }
				}
			}
		},
		"/v1/history-scan/job": {
			"get": {
				"summary": "Claim the next pending history scan job",
				"description": "Internal authenticated worker endpoint. Atomically marks one pending history archive scan job as taken and returns it to a scanner.",
				"tags": ["HistoryScan"],
				"operationId": "getHistoryScanJob",
				"security": [{ "basicAuth": [] }],
				"responses": {
					"200": {
						"description": "scan job claimed",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"required": ["url", "remoteId"],
									"properties": {
										"url": { "type": "string" },
										"remoteId": { "type": "string", "format": "uuid" },
										"latestScannedLedger": { "type": "integer" },
										"latestScannedLedgerHeaderHash": {
											"type": "string",
											"nullable": true
										},
										"chainInitDate": {
											"type": "string",
											"format": "date-time",
											"nullable": true
										},
										"fromLedger": {
											"type": "integer",
											"nullable": true
										},
										"toLedger": {
											"type": "integer",
											"nullable": true
										},
										"concurrency": {
											"type": "integer",
											"nullable": true
										}
									}
								}
							}
						}

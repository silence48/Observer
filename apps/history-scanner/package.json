{
	"name": "history-scanner",
	"version": "2.0.0",
	"description": "Scan history archives",
	"type": "module",
	"scripts": {
		"build": "tsc --declaration && pnpm -w rewrite:aliases apps/history-scanner",
		"build-and-start": "pnpm build; node lib/index.js",
		"start": "node lib/index.js",
		"build-and-scan-history": "pnpm run build; node lib/infrastructure/cli/verify-archives.js",
		"scan-history": "node lib/infrastructure/cli/verify-archives.js 1 1",
		"scan-single-archive": "node lib/infrastructure/cli/verify-single-archive.js"
	},
	"types": "lib/index.d.ts",
	"main": "index.js",
	"license": "MIT",
	"private": true,
	"dependencies": {
		"@stellar/stellar-sdk": "16.0.1",
		"ajv": "^8.20.0",
		"custom-error": "workspace:*",
		"dotenv": "^17.4.2",
		"exception-logger": "workspace:*",
		"history-scanner-dto": "workspace:*",
		"http-helper": "workspace:*",
		"inversify": "^6.0.2",
		"job-monitor": "workspace:*",
		"logger": "workspace:*",
		"neverthrow": "^8.2.0",
		"shared": "workspace:*",
		"validator": "^13.15.35",
		"workerpool": "^10.0.2",
		"yn": "^5.1.0"
	},
	"devDependencies": {
		"@types/express": "^4.17.21",
		"@types/jest": "30.0.0",
		"@types/node": "^26.0.1",
		"express": "^4.21.2",
		"reflect-metadata": "^0.2.2",
		"supertest": "^7.2.2",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": "26.x"
	}
}

{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "lib",
		"rootDir": "src",
		"composite": true,
		"paths": {
			"@users/*.js": [
				"./src/*.ts"
			],
			"@users/*": [
				"./src/*"
			],
			"@migrations/*.js": [
				"./src/migrations/*.ts"
			],
			"@migrations/*": [
				"./src/migrations/*"
			]
		}
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules/**/*"
	]
}

{
	"name": "node-connector",
	"version": "2.0.0",
	"description": "Connect and interact with nodes in the Stellar Network over the tcp protocol",
	"type": "module",
	"scripts": {
		"build": "tsc --declaration && pnpm -w rewrite:aliases packages/node-connector",
		"examples:connect": "pnpm run build; node lib/examples/connect.js",
		"examples:scp": "pnpm run build; node lib/examples/scp.js"
	},
	"types": "lib/index.d.ts",
	"main": "lib/index.js",
	"author": "pieterjan84@github",
	"license": "MIT",
	"dependencies": {
		"async": "^3.2.6",
		"sodium-native": "^4.1.1",
		"workerpool": "^10.0.2",
		"yn": "^5.1.0"
	},
	"devDependencies": {
		"@types/async": "^3.2.25",
		"@types/sodium-native": "^2.3.9",
		"bignumber.js": "11.1.4"
	},
	"engines": {
		"node": "26.x"
	}
}

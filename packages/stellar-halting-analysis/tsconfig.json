{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "lib",
		"rootDir": "src",
		"composite": true,
		"types": [
			"node"
		],
		"paths": {
			"@stellar-halting-analysis/*.js": [
				"./src/*.ts"
			],
			"@stellar-halting-analysis/*": [
				"./src/*"
			]
		}
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules/**/*",
		"src/**/__tests__/*"
	]
}

{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "lib",
		"rootDir": "src",
		"composite": true,
		"paths": {
			"@crawler/*.js": [
				"./src/*.ts"
			],
			"@crawler/*": [
				"./src/*"
			],
			"@fixtures/*.js": [
				"./src/__fixtures__/*.ts"
			],
			"@fixtures/*": [
				"./src/__fixtures__/*"
			],
			"@network-observer/*.js": [
				"./src/network-observer/*.ts"
			],
			"@network-observer/*": [
				"./src/network-observer/*"
			],
			"@utilities/*.js": [
				"./src/utilities/*.ts"
			],
			"@utilities/*": [
				"./src/utilities/*"
			]
		}
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"node_modules/**/*",
		"src/**/__tests__/*",
		"src/**/__mocks__/*",
		"src/**/__fixtures__/*"
	]
}
